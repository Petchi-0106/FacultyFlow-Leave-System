 application "Faculty Leave Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form hod_master
		{
			displayname = "HOD Master"
			success message = "Hod Master Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			hod_name
			(
    			type = text
				displayname = "HOD Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			department
			(
				type = picklist
				displayname = "Department"
				values = {"Civil","Chemical","CSE","EEE","ECE","IT","Biomedical"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			email
			(
    			type = email
				displayname = "Email"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form leave_request
		{
			displayname = "Leave Request"
			success message = "Leave Request Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			staff
			(
				type = list	
				displayname = "Staff"
				values  = staff_master.ID
    			displayformat = [employee_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			leave_type
			(
				type = picklist
				displayname = "Leave Type"
				values = {"On Duty","Sick","Casual","Earned"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			from_date
			(
    			type = date
				displayname = "From Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			to_date
			(
    			type = date
				displayname = "To Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			number_of_days
			(
				type = number
				displayname = "Number of Days"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			reason
			(
    			type = textarea
				displayname = "Reason"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Approved","Rejected","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			department
			(
				type = list	
				displayname = "Department"
				values  = staff_master.ID
    			displayformat = [employee_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Leave Request Submitted","Leave Request Under Review","Leave Request Draft","Leave Request Approved","Leave Request Rejected","Leave Request Requesting Clarification","Leave Request Confirmed","Leave Request Cancelled","Leave Request In Progress","Leave Request Completed","Leave Request Extended","Leave Request Closed"}
			}
		}
		form staff_master
		{
			displayname = "Staff Master"
			success message = "Staff Master Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			employee_id
			(
    			type = autonumber
				displayname = "Employee ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			staff_name
			(
    			type = text
				displayname = "Staff Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			email
			(
    			type = email
				displayname = "Email"
	 			row = 1
	 			column = 1   
				width = medium
			)
			phone_number
			(
    			type = phonenumber
				displayname = "Phone Number"
	 			row = 1
	 			column = 1   
				width = medium
			)
			department
			(
				type = picklist
				displayname = "Department"
				values = {"Civil","Chemical","CSE","EEE","ECE","IT","Biomedical"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			designation
			(
    			type = text
				displayname = "Designation"
	 			row = 1
	 			column = 1   
				width = medium
			)
			leave_balance
			(
				type = number
				displayname = "Leave Balance"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Staff Record Created","Leave Balance Initialized","Staff Record Pending Approval","Staff Record Rejected","Leave Balance Updated","Leave Balance Review Required","Leave Balance Verified","Leave Balance Rejected","Leave Balance Active","Leave Request Submitted","Leave Balance Adjusted","Leave Request Under Review","Leave Request Rejected","Leave Request Approved","Leave Request Pending Additional Info","Leave Period Active","Leave Request Cancelled","Leave Period Completed","Leave Period Extended","Leave Period Terminated","Leave Balance Replenished","Leave Period Reopened"}
			}
		}
	}
	reports
	{
		list leave_request_Report
		{
			displayName = "All Leave Requests"
			show all rows from leave_request    
			(
				staff as "Staff"
				leave_type as "Leave Type"
				from_date as "From Date"
				to_date as "To Date"
				number_of_days as "Number of Days"
				reason as "Reason"
				status as "Status"
				department as "Department"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (leave_type == "Earned")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (leave_type == "On Duty")
				fields = [leave_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban leave_request_by_leave_type
		{
			displayName = "Leave Types"
			show all rows from leave_request    
			(
				staff as "Staff"
				leave_type as "Leave Type"
				from_date as "From Date"
				to_date as "To Date"
				number_of_days as "Number of Days"
				reason as "Reason"
				status as "Status"
				department as "Department"
			)
			options
			(
	 			display field = leave_type
	 		)
		}
		list hod_master_Report
		{
			displayName = "All Hod Masters"
			show all rows from hod_master    
			(
				hod_name as "HOD Name"
				department as "Department"
				email as "Email"
			)
		}
		kanban hod_master_by_department
		{
			displayName = "Departments"
			show all rows from hod_master    
			(
				hod_name as "HOD Name"
				department as "Department"
				email as "Email"
			)
			options
			(
	 			display field = department
	 		)
		}
		list staff_master_Report
		{
			displayName = "All Staff Masters"
			show all rows from staff_master    
			(
				employee_id as "Employee ID"
				staff_name as "Staff Name"
				email as "Email"
				phone_number as "Phone Number"
				department as "Department"
				designation as "Designation"
				leave_balance as "Leave Balance"
			)
		}
		kanban staff_master_by_department
		{
			displayName = "Departments"
			show all rows from staff_master    
			(
				employee_id as "Employee ID"
				staff_name as "Staff Name"
				email as "Email"
				phone_number as "Phone Number"
				department as "Department"
				designation as "Designation"
				leave_balance as "Leave Balance"
			)
			options
			(
	 			display field = department
	 		)
		}
	}
